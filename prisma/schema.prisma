datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id           String @id
  age          Int    @default(16)
  heightCm     Int    @default(175)
  weightKg     Int    @default(70)
  pullUpsMax   Int    @default(15)
  muscleUpsMax Int    @default(3)
  pushUpsMax   Int    @default(48)
  plancheStage Int    @default(1)
  flStage      Int    @default(1)
  startDate    String
}

model WorkoutSession {
  id         String   @id
  date       String
  dayType    String
  weekNumber Int
  isDeload   Boolean
  completed  Boolean  @default(true)
  notes      String?
  exercises  String   // JSON string of exercises array
  createdAt  DateTime @default(now())
}

model MaxHold {
  id             String @id
  exerciseName   String
  maxHoldSeconds Int
  lastTestedAt   String
}

model PainReport {
  id          String  @id
  date        String
  bodyPart    String
  severity    Int
  notes       String?
  exerciseId  String?
  actionTaken String?
}
